# SovGuard Engine Configuration

# Server port
SOVGUARD_PORT=3100

# Bind address (127.0.0.1 for local, 0.0.0.0 for Docker)
SOVGUARD_HOST=127.0.0.1

# API key for authenticating requests
SOVGUARD_API_KEY=your-secret-api-key

# Lakera Guard API key (optional — ML classifier disabled without it)
# Free tier: 10K requests/month at https://platform.lakera.ai
# LAKERA_API_KEY=your_key_here

# Self-hosted DeBERTa classifier (optional — falls back to Lakera API or disabled)
# Run: scripts/download-model.sh to download the ONNX model
# SOVGUARD_MODEL_DIR=./models/deberta-v3-prompt-injection
# SOVGUARD_CLASSIFIER_MODE=auto  # 'local' | 'lakera' | 'auto' (default: auto)

# SQLite database path (for scan logs, canary tokens, audit, reports)
# SOVGUARD_DB_PATH=./sovguard.db
